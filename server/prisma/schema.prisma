generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// One registered account. Username is unique and immutable; password
// is bcrypt-hashed. The user matching ADMIN_USERNAME on first startup
// has isOperator forced to true.
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(32)
  passwordHash String   @db.VarChar(72)
  isOperator   Boolean  @default(false)
  createdAt    DateTime @default(now())

  sendKeys SendKey[]
  sendLogs SendLog[]
}

// One OneBot-connected QQ account managed by an Operator. The Channel acts
// as a forward WebSocket client against `wsUrl`.
model Bot {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(64)
  qq          BigInt   @unique
  wsUrl       String   @db.VarChar(255)
  accessToken String?  @db.VarChar(255)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  friendships Friendship[]
  sendKeys    SendKey[]
}

// (botId, qq) -> "this bot has this QQ as a confirmed friend".
// Populated on startup, refreshed every 24h, and updated incrementally when
// the Channel auto-approves a friend request during a pending key creation.
model Friendship {
  botId     Int
  qq        BigInt
  updatedAt DateTime @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@id([botId, qq])
}

// One pre-shared credential the caller includes in every Send request.
// Plaintext is generated server-side and stored alongside the bcrypt hash
// so the user can re-copy it from the management UI. The hash is what the
// /send endpoint validates against — even if the table is dumped, callers
// still need a valid plaintext to send. `prefix` (first 8 chars) doubles as
// a fast lookup key for the bcrypt verify step.
model SendKey {
  id            Int       @id @default(autoincrement())
  userId        Int
  name          String    @db.VarChar(64)
  targetQq      BigInt
  botId         Int
  state         String    @default("active") @db.VarChar(16)
  keyHash       String    @db.VarChar(72)
  keyPlaintext  String?   @db.VarChar(64)
  prefix        String    @db.VarChar(16)
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot  Bot  @relation(fields: [botId], references: [id])
  logs SendLog[]

  @@index([userId])
  @@index([botId])
  @@index([prefix])
}

// One row per attempted /send call, success or failure. Lets the owner
// (and operators) see exactly what was pushed, when, by which bot, with
// what outcome. Cascades on user deletion and on the parent SendKey
// being deleted so logs never outlive their context.
//
// `content` is stored as-is up to 4000 chars (matches the send-time cap);
// `title` follows the API's 100-char cap. `statusCode` mirrors the HTTP
// reply (0/200 success synonym, 401/502/503 failure modes). `reason`
// holds the machine code (`send_failed`, `send_key_disabled`, etc.) when
// non-success; null on success.
model SendLog {
  id            Int      @id @default(autoincrement())
  sendKeyId     Int
  userId        Int
  botId         Int?
  targetQq      BigInt
  title         String?  @db.VarChar(100)
  content       String   @db.VarChar(4000)
  statusCode    Int
  reason        String?  @db.VarChar(64)
  durationMs    Int
  hasAttachment Boolean  @default(false)
  createdAt     DateTime @default(now())

  sendKey    SendKey      @relation(fields: [sendKeyId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachment SendLogFile?

  @@index([sendKeyId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// File payload for file-mode sends, kept in a sibling table so the main
// SendLog row stays light for paginated audit listing. `data` is the raw
// upload bytes; we hand them back unchanged on download. Cascades on the
// parent SendLog being removed (which itself cascades on key/user delete).
model SendLogFile {
  sendLogId Int     @id
  fileName  String  @db.VarChar(255)
  mimeType  String? @db.VarChar(127)
  byteCount Int
  data      Bytes   @db.LongBlob

  sendLog SendLog @relation(fields: [sendLogId], references: [id], onDelete: Cascade)
}
